{
    "AllowedHosts": "*",
    "Serilog":
    {
        "Using":
        [
            "Serilog.Sinks.File"
        ],
        "MinimumLevel":
        {
            "Default": "Information",
            "Override":
            {
                "Microsoft.AspNetCore": "Warning"
            }
        },
        "WriteTo":
        [
            {
                "Name": "File",
                "Args":
                {
                    "path": "..\\..\\..\\..\\output\\logs\\authority.consoleapp..log",
                    "rollingInterval": "Day",
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd}][{Timestamp:HH:mm:ss.fff}][{Timestamp:zzz}]<{Level:u3}>: {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    },
    "ConnectionStrings":
    {
        "authoritydb-sqlite": "Data Source=..\\..\\..\\..\\output\\databases\\authority.db",
        "authoritydb-sql": "Data Source=localhost;Initial Catalog=Lexicom.Cinema.Authority;Integrated Security=True;TrustServerCertificate=True"
    },
    "BrandOptions":
    {
        "CompanyName": "Lexicom",
        "AppName": "Cinema"
    },
    "UrlsOptions":
    {
        "ConfirmationEmailUrl": "https://www.cinema.com/user/email/confirm",
        "ForgotPasswordEmailUrl": "https://www.cinema.com/movies/user/password/reset"
    },
    "SmtpEmailFileClientOptions":
    {
        "OutputDirectoryPath": "..\\output\\emails",
        "FileName": "email",
        "FileExtension": "html"
    }
}
