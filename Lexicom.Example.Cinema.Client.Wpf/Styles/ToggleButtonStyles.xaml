<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="xDefaultToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeInteriorPrimarySoft}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ThemeSurfacePrimaryHard}"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeInteriorPrimaryHard}"/>
            </Trigger>
            <!--<Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ThemeSurfaceSecondarySoft}"/>
            </Trigger>-->
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource ThemeSurfacePrimarySoft}"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeInteriorFocusSoft}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ToggleButton" BasedOn="{StaticResource xDefaultToggleButtonStyle}"/>

</ResourceDictionary>